# URL Discovery Service for Bangladeshi Government Websites
# This file contains all sensitive credentials
# COPY THIS FILE TO .env AND UPDATE WITH YOUR VALUES

# ============================================
# PostgreSQL Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=url_discovery
DB_PASSWORD=your_secure_password_here
DB_NAME=url_discovery_db

# ============================================
# Crawler Configuration
# ============================================
CRAWLER_SEED_FILE=seeds/input.txt
CRAWLER_MAX_CONCURRENT_REQUESTS=50
CRAWLER_TIMEOUT=15
CRAWLER_POLITENESS_DELAY=0.2
CRAWLER_USER_AGENT="BD-Gov-Discovery-Service/1.0"

# ============================================
# Scheduler Configuration
# ============================================
SCHEDULER_CHECK_INTERVAL=300
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_DELAY=60

# ============================================
# Liveness Check Configuration
# ============================================
LIVENESS_HTTP_CHECK=true
LIVENESS_HTTPS_CHECK=true
LIVENESS_TIMEOUT=7

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/discovery.log
LOG_ROTATION="10 MB"
LOG_RETENTION="10 days"

# ============================================
# Metrics Configuration (Optional)
# ============================================
METRICS_ENABLED=false
METRICS_PORT=8080
