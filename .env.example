# ==========================================
# URL Discovery Engine - Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ------------------------------------------
# PostgreSQL Database Configuration
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password

# Database names for different modules
BD_GOV_DB_NAME=bd_gov_db
GOV_BD_DB_NAME=gov_bd_db
BANGLAPEDIA_DB_NAME=banglapedia_db

# ------------------------------------------
# vLLM LLM Configuration
# ------------------------------------------
VLLM_BASE_URL=http://localhost:5000/v1
VLLM_API_KEY=no-key
LLM_MODEL_NAME=qwen35

# ------------------------------------------
# Triton Inference Server (Embeddings)
# ------------------------------------------
TRITON_URL=localhost:7000

# ------------------------------------------
# Elasticsearch Configuration
# ------------------------------------------
ES_HOST=http://localhost:9200
ES_INDEX_NAME=bd_gov_chunks

# ------------------------------------------
# Gradio UI Configuration
# ------------------------------------------
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# ------------------------------------------
# Crawler Configuration
# ------------------------------------------
CRAWLER_MAX_CONCURRENT_REQUESTS=30
CRAWLER_TIMEOUT=15
LIVENESS_TIMEOUT=7
LIVENESS_MAX_CONCURRENT=100
CRAWLER_USER_AGENT=BD-Gov-Ecosystem-Mapper/3.0 (Research)

# ------------------------------------------
# Logging Configuration
# ------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ------------------------------------------
# DeepEval Configuration
# ------------------------------------------
DEEPEVAL_TELEMETRY_OPT_OUT=YES
